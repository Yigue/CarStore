            "body": { "mode": "raw", "raw": "{\n    \"firstName\": \"Juan\",\n    \"lastName\": \"Pérez\",\n    \"email\": \"juan.perez@email.com\",\n    \"phone\": \"+54 11 1234-5678\",\n    \"address\": \"Av. Corrientes 1234, CABA\",\n    \"dni\": \"30123456\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/clients", "host": ["{{baseUrl}}"], "path": ["api", "v1", "clients"] }
          }
